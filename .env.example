# Public contact details (shown on /contact)
CONTACT_EMAIL=info@multiactivecard.com
CONTACT_PHONE=+355 123 456 789

# Email API (optional — used by /api/test-email and if you re-enable contact forms)
# Get a key at https://resend.com/api-keys
# RESEND_API_KEY=

# Sender (must be a domain/address allowed in your Resend account)
# FROM_EMAIL=noreply@multiactivecard.com
# FROM_NAME=Multi Active Card

# Inbox addresses (comma-separated) that receive form submissions
# PARTNER_EMAILS=info@multiactivecard.com
# CLIENT_EMAILS=info@multiactivecard.com

# Optional rate limit (defaults: 5 requests per 15 minutes per IP)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=5
